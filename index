async function openScanner() {
    show('mScanner');
    if ($('manualQrInput')) $('manualQrInput').value = '';
    if ($('scannerHint')) $('scannerHint').textContent = 'กำลังตรวจสอบกล้อง...';

    if (!window.isSecureContext) {
        Swal.fire('เปิดกล้องไม่ได้', 'เบราว์เซอร์จะอนุญาตกล้องเฉพาะหน้าเว็บ HTTPS เท่านั้น กรุณาเปิดผ่านลิงก์ GitHub Pages ที่เป็น HTTPS', 'warning');
        return;
    }

    if (typeof Html5Qrcode === 'undefined') {
        Swal.fire('โหลดตัวสแกนไม่สำเร็จ', 'ไม่พบไลบรารี html5-qrcode กรุณาตรวจสอบอินเทอร์เน็ตหรือรีเฟรชหน้าเว็บ', 'error');
        return;
    }

    try {
        const cameras = await Html5Qrcode.getCameras();
        const sel = $('cameraSelect');
        sel.innerHTML = '';

        if (!cameras || cameras.length === 0) {
            sel.innerHTML = '<option value="">ไม่พบกล้อง</option>';
            $('scannerHint').textContent = 'ไม่พบกล้องบนอุปกรณ์นี้ หรือยังไม่ได้อนุญาตสิทธิ์การใช้กล้อง';
            return;
        }

        cameras.forEach((camera, index) => {
            const opt = document.createElement('option');
            opt.value = camera.id;
            opt.textContent = camera.label || `กล้อง ${index + 1}`;
            const label = (camera.label || '').toLowerCase();
            if (label.includes('back') || label.includes('rear') || label.includes('environment')) opt.selected = true;
            sel.appendChild(opt);
        });

        await startSelectedCamera();
    } catch (err) {
        console.error('Camera list error:', err);
        $('scannerHint').textContent = 'ยังไม่สามารถเข้าถึงกล้องได้';
        Swal.fire('ไม่สามารถเปิดกล้องได้', 'กรุณากดอนุญาตกล้องในเบราว์เซอร์ แล้วเปิดผ่านลิงก์ GitHub Pages ที่เป็น HTTPS', 'error');
    }
}

async function startSelectedCamera() {
    try {
        if (html5QrCode) {
            try { await html5QrCode.stop(); } catch (e) {}
            try { await html5QrCode.clear(); } catch (e) {}
            html5QrCode = null;
        }

        const cameraId = $('cameraSelect')?.value;
        if (!cameraId) {
            $('scannerHint').textContent = 'กรุณาเลือกกล้องก่อนเริ่มสแกน';
            return;
        }

        html5QrCode = new Html5Qrcode('qr-reader');
        const qrSize = Math.min(Math.max(Math.floor(window.innerWidth * 0.65), 220), 320);

        $('scannerHint').textContent = 'กำลังเปิดกล้อง...';
        await html5QrCode.start(
            cameraId,
            { fps: 10, qrbox: { width: qrSize, height: qrSize }, aspectRatio: 1.0 },
            onScanSuccess,
            onScanFailure
        );
        $('scannerHint').textContent = 'หันกล้องไปที่ QR Code ของเอกสาร ระบบจะเปิดหน้ารายละเอียดให้อัตโนมัติ';
    } catch (err) {
        console.error('Camera start error:', err);
        $('scannerHint').textContent = 'เปิดกล้องไม่สำเร็จ กรุณาตรวจสอบสิทธิ์ Camera';
        Swal.fire('ไม่สามารถเปิดกล้องได้', 'กรุณาอนุญาตการใช้งานกล้อง หรือเปลี่ยนไปใช้ Chrome/Safari เวอร์ชันล่าสุด', 'error');
    }
}

async function closeScanner() {
    if (html5QrCode) {
        try { await html5QrCode.stop(); } catch (err) { console.log('Stop error:', err); }
        try { await html5QrCode.clear(); } catch (err) { console.log('Clear error:', err); }
        html5QrCode = null;
    }
    hide('mScanner');
}

function extractDocIdFromQr(text) {
    const value = (text || '').toString().trim();
    if (!value) return '';

    try {
        const url = new URL(value);
        return (url.searchParams.get('id') || '').trim();
    } catch (e) {
        // รองรับกรณี QR เป็นเฉพาะ UUID หรือมีข้อความ id=...
        const match = value.match(/[?&]id=([^&\s]+)/i) || value.match(/id[:=]\s*([a-zA-Z0-9\-]+)/i);
        if (match) return decodeURIComponent(match[1]).trim();
        return value;
    }
}

function handleManualQrInput() {
    const id = extractDocIdFromQr($('manualQrInput').value);
    if (!id) return Swal.fire('แจ้งเตือน', 'กรุณากรอกลิงก์ QR หรือ ID เอกสาร', 'warning');
    openScannedDocument(id);
}

function onScanSuccess(decodedText) {
    const id = extractDocIdFromQr(decodedText);
    if (!id) {
        Swal.fire('QR ไม่ถูกต้อง', 'ไม่พบ ID ใน QR Code', 'error');
        return;
    }
    openScannedDocument(id);
}

async function openScannedDocument(id) {
    await closeScanner();
    DOC_ID = id;
    loadUpdate(id);
    Swal.fire({ title: 'สแกนสำเร็จ!', text: 'เปิดข้อมูลเอกสารแล้ว', icon: 'success', timer: 900, showConfirmButton: false });
}

function onScanFailure(error) {}

// Update View
function loadUpdate(id) {
    show('vUpdate');
    hide('vDash');
    hide('vLogin');
    hide('vEdit');
    loader(true);
    api('getDocumentById', { id }).then(r => {
        loader(false);
        if (r.success && r.data) {
            const d = r.data;
            $('uDocNo').textContent = d.docNo || '-';
            $('uDocNoOW').textContent = d.docNoOW || '-';
            $('uType').innerHTML = `<span class="badge ${typeCls(d.type)}">${esc(d.type)}</span>`;
            $('uTopic').textContent = d.topic || '-';
            $('uOwner').textContent = d.owner || '-';
            $('uStatus').textContent = d.currentStatus || '-';
            $('uStatus').className = 'pill ' + statusCls(d.currentStatus || '');
            $('uLog').textContent = d.log || 'ยังไม่มีประวัติ';
        } else Swal.fire('ไม่พบข้อมูล', r.error, 'error');
    }).catch(e => { loader(false); Swal.fire('Error', e.message, 'error'); });
}

function goUpdatePage(id) { 
    window.open(CFG.WEBAPP_URL + '?view=update&id=' + id, '_blank');
}

function doUpdateStatus() {
    const status = $('selStatus').value, name = $('updater').value.trim();
    if (!name) return Swal.fire('แจ้งเตือน', 'กรุณาระบุชื่อผู้ดำเนินการ', 'warning');
    
    loader(true);
    api('updateDocumentStatus', { id: DOC_ID, newStatus: status, updater: name }).then(r => {
        loader(false);
        if (r.success) {
            $('uStatus').textContent = r.data.currentStatus;
            $('uStatus').className = 'pill ' + statusCls(r.data.currentStatus);
            $('uLog').textContent = r.data.log;
            $('updater').value = '';
            Swal.fire({ title: 'สำเร็จ', text: 'อัพเดทสถานะเรียบร้อย', icon: 'success', timer: 1000, showConfirmButton: false });
        } else Swal.fire('Error', r.error, 'error');
    }).catch(onErr);
}

// Edit View
function loadEdit(id) {
    show('vEdit');
    hide('vDash');
    hide('vLogin');
    hide('vUpdate');
    loader(true);
    api('getDocumentById', { id }).then(r => {
        loader(false);
        if (r.success && r.data) {
            const d = r.data;
            $('eDocNo').value = d.docNo || '';
            $('eDocNoOW').value = d.docNoOW || '';
            $('eType').value = d.type || 'หนังสือรับ';
            $('eTopic').value = d.topic || '';
            $('eDate').value = d.rawDate || '';
            $('eOwner').value = d.owner || '';
            $('eStatus').textContent = d.currentStatus || '-';
            $('eStatus').className = 'pill ' + statusCls(d.currentStatus || '');
        } else Swal.fire('ไม่พบข้อมูล', r.error, 'error').then(goHomeDash);
    }).catch(e => { loader(false); Swal.fire('Error', e.message, 'error').then(goHomeDash); });
}

function goEdit(id) { 
    location.href = CFG.WEBAPP_URL + '?view=edit&id=' + id + '&auth=1'; 
}

function doEdit(e) {
    e.preventDefault();
    loader(true);
    api('editDocument', {
        id: DOC_ID,
        form: {
            docType: $('eType').value,
            topic: $('eTopic').value,
            docDate: $('eDate').value,
            owner: $('eOwner').value,
            docNo: $('eDocNo').value,
            docNoOW: $('eDocNoOW').value
        }
    }).then(r => {
        loader(false);
        if (r.success) {
            Swal.fire({ title: 'สำเร็จ', text: 'แก้ไขข้อมูลเรียบร้อย', icon: 'success', timer: 1000, showConfirmButton: false }).then(goHomeDash);
        } else Swal.fire('Error', r.error, 'error');
    }).catch(onErr);
    return false;
}

function goHomeDash() {
    sessionStorage.setItem('auth', '1');
    location.href = CFG.WEBAPP_URL + '?auth=1';
}
</script>
