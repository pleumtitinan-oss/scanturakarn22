// Auto Refresh Functions
function initAutoRefresh() {
    const toggle = $('autoRefresh');
    if (toggle.checked) {
        startAutoRefresh();
    }
    
    toggle.addEventListener('change', function() {
        if (this.checked) {
            startAutoRefresh();
        } else {
            stopAutoRefresh();
        }
    });
}

function startAutoRefresh() {
    stopAutoRefresh();
    refreshCountdown = AUTO_REFRESH_SECONDS;
    updateRefreshTimer();
    show('refreshTimer');
    
    autoRefreshInterval = setInterval(() => {
        refreshCountdown--;
        updateRefreshTimer();
        
        if (refreshCountdown <= 0) {
            refreshCountdown = AUTO_REFRESH_SECONDS;
            doRefresh(true); // silent refresh
        }
    }, 1000);
}

function stopAutoRefresh() {
    if (autoRefreshInterval) {
        clearInterval(autoRefreshInterval);
        autoRefreshInterval = null;
    }
    hide('refreshTimer');
}

function updateRefreshTimer() {
    const timerEl = $('refreshTimer');
    if (timerEl) {
        timerEl.textContent = refreshCountdown + 's';
        if (refreshCountdown <= 5) {
            timerEl.classList.add('text-orange-500');
            timerEl.classList.remove('text-blue-600');
        } else {
            timerEl.classList.remove('text-orange-500');
            timerEl.classList.add('text-blue-600');
        }
    }
}

