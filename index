function dlQrWithHeader() {
    const qrImg = $('qrBox').querySelector('img');
    if (!qrImg) return;
    
    const canvas = $('qrCanvas');
    const ctx = canvas.getContext('2d');
    
    // === ตั้งค่าสัดส่วน (3 : 2) ===
    const scale = 5; 
    
    // กำหนดขนาดฐาน (Base Size) 3.3cm x 2.2cm
    const baseW = 330; 
    const baseH = 220; 
    
    const canvasWidth = baseW * scale;
    const canvasHeight = baseH * scale;
    
    canvas.width = canvasWidth;
    canvas.height = canvasHeight;
    
    // 1. วาดพื้นหลังสีขาว
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvasWidth, canvasHeight);
    
    // 2. วาดกรอบสี่เหลี่ยมสีดำ (ขอบบาง) รอบนอก
    ctx.strokeStyle = '#000000';
    ctx.lineWidth = 2 * scale;
    ctx.strokeRect(5 * scale, 5 * scale, canvasWidth - (10 * scale), canvasHeight - (10 * scale));
    
    // === 3. คำนวณตำแหน่งและขนาด QR (แบบไม่เบียด) ===
    const qrSize = (baseH - 60) * scale; 
    const qrX = canvasWidth - qrSize - (20 * scale);
    const qrY = (canvasHeight - qrSize) / 2;
    
    // === 4. จัดตำแหน่งตัวหนังสือ (ชิดซ้าย) ===
    const textX = 25 * scale; 
    ctx.textAlign = 'left';
    ctx.fillStyle = '#000000'; // สีดำ
    
    // --- บรรทัดที่ 1: ชื่องาน (บังคับข้อความสั้น) ---
    ctx.font = 'bold ' + (14 * scale) + 'px Sarabun, sans-serif'; 
    
    // [แก้ตรงนี้] ใส่ข้อความสั้นๆ ตรงๆ เลย ไม่ใช้ตัวแปร เพื่อไม่ให้ยาวเกินไป
    ctx.fillText("งานคลังและพัสดุ", textX, (45 * scale)); 
    
    // --- บรรทัดที่ 2: เลขรับ (ตัดเหลือ 4 หลัก) ---
    ctx.font = 'bold ' + (55 * scale) + 'px Arial, sans-serif';
    let showDocNo = String(CURRENT_QR_DATA.docNo || "");
    if (showDocNo.length > 4) {
        showDocNo = showDocNo.slice(-4);
    }
    ctx.fillText(showDocNo, textX, (110 * scale)); 
    
    // --- บรรทัดที่ 3: เวลา ---
    ctx.font = (24 * scale) + 'px Arial, sans-serif';
    ctx.fillText(CURRENT_QR_DATA.time, textX, (155 * scale));
    
    // --- บรรทัดที่ 4: วันที่ ---
    let shortDate = CURRENT_QR_DATA.date; 
    ctx.fillText(shortDate, textX, (190 * scale));
    
    // 5. วาดรูป QR Code
    const img = new Image();
    img.crossOrigin = "Anonymous";
    img.onload = function() {
        ctx.imageSmoothingEnabled = false; 
        ctx.drawImage(img, qrX, qrY, qrSize, qrSize);
        
        const a = document.createElement('a');
        a.href = canvas.toDataURL('image/png', 1.0);
        a.download = 'label_' + CURRENT_QR_DATA.docNo + '.png';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
    };
    img.src = qrImg.src;
}
