// Populate Month Filter
function populateMonthFilter() {
    const select = $('monthFilter');
    // Save current selection
    const currentVal = select.value;
    
    select.innerHTML = '<option value="">ทุกเดือน</option>';
    
    const months = new Set();
    DOCS.forEach(d => {
        if (d.createdDate) {
            const parts = d.createdDate.split('/');
            if (parts.length >= 2) {
                months.add(parts[1] + '/' + parts[2]); // MM/YYYY
            }
        }
    });
    
    Array.from(months).sort().reverse().forEach(m => {
        const opt = document.createElement('option');
        opt.value = m;
        const [mm, yy] = m.split('/');
        opt.textContent = THAI_MONTHS[parseInt(mm)-1] + ' ' + (parseInt(yy));
        if (m === currentVal) opt.selected = true;
        select.appendChild(opt);
    });
}

// Monthly Dashboard
function updateMonthlyDashboard() {
    selectedYear = parseInt($('yearSelect').value);
    renderMonthCards();
    renderMonthlyChart();
}

function renderMonthCards() {
    const container = $('monthCards');
    container.innerHTML = '';
    
    const monthStats = getMonthlyStats();
    
    for (let m = 0; m < 12; m++) {
        const key = `${selectedYear}-${String(m+1).padStart(2,'0')}`;
        const stat = monthStats[key] || { total: 0, done: 0, pending: 0 };
        const percent = stat.total > 0 ? Math.round((stat.done / stat.total) * 100) : 0;
        
        const card = document.createElement('div');
        card.className = `month-card bg-white border rounded-lg p-3 text-center ${selectedMonth === m ? 'border-blue-500 ring-2 ring-blue-200' : ''}`;
        card.onclick = () => selectMonth(m);
        
        card.innerHTML = `
            <div class="text-xs text-gray-500">${THAI_MONTHS[m]}</div>
            <div class="text-lg font-bold ${stat.total > 0 ? 'text-blue-600' : 'text-gray-300'}">${stat.total}</div>
            <div class="w-full bg-gray-200 rounded-full h-1.5 mt-1">
                <div class="bg-green-500 h-1.5 rounded-full" style="width: ${percent}%"></div>
            </div>
            <div class="text-xs mt-1 ${stat.done > 0 ? 'text-green-600' : 'text-gray-400'}">เสร็จ ${stat.done}</div>
        `;
        container.appendChild(card);
    }
}

function getMonthlyStats() {
    const stats = {};
    
    DOCS.forEach(d => {
        if (d.createdDate) {
            const parts = d.createdDate.split('/');
            if (parts.length >= 3) {
                const year = parseInt(parts[2]);
                const month = parseInt(parts[1]);
                const key = `${year}-${String(month).padStart(2,'0')}`;
                
                if (!stats[key]) {
                    stats[key] = { total: 0, done: 0, pending: 0, byType: {}, byStatus: {} };
                }
                
                stats[key].total++;
                
                if (d.status.includes('เสร็จ') || d.status.includes('อนุมัติ')) {
                    stats[key].done++;
                } else {
                    stats[key].pending++;
                }
                
                // By type
                const type = d.type || 'อื่นๆ';
                stats[key].byType[type] = (stats[key].byType[type] || 0) + 1;
                
                // By status
                stats[key].byStatus[d.status] = (stats[key].byStatus[d.status] || 0) + 1;
            }
        }
    });
    
    return stats;
}

function selectMonth(m) {
    selectedMonth = selectedMonth === m ? null : m;
    renderMonthCards();
    renderMonthlyDetail();
}

function renderMonthlyDetail() {
    const container = $('monthlyDetail');
    
    if (selectedMonth === null) {
        container.innerHTML = '<p class="text-gray-500 text-center py-4">เลือกเดือนเพื่อดูรายละเอียด</p>';
        return;
    }
    
    const key = `${selectedYear}-${String(selectedMonth+1).padStart(2,'0')}`;
    const stats = getMonthlyStats()[key];
    
    if (!stats || stats.total === 0) {
        container.innerHTML = `<p class="text-gray-500 text-center py-4">ไม่มีข้อมูลในเดือน ${THAI_MONTHS_FULL[selectedMonth]} ${selectedYear + 543}</p>`;
        return;
    }
    
    const percent = Math.round((stats.done / stats.total) * 100);
    
    let html = `
        <div class="bg-gradient-to-r from-blue-500 to-indigo-500 text-white rounded-lg p-3 mb-3">
            <div class="text-sm opacity-80">${THAI_MONTHS_FULL[selectedMonth]} ${selectedYear + 543}</div>
            <div class="text-2xl font-bold">${stats.total} เอกสาร</div>
        </div>
        
        <div class="grid grid-cols-2 gap-2 mb-3">
            <div class="bg-green-50 rounded-lg p-2 text-center">
                <div class="text-green-600 font-bold text-lg">${stats.done}</div>
                <div class="text-xs text-green-700">เสร็จสิ้น (${percent}%)</div>
            </div>
            <div class="bg-yellow-50 rounded-lg p-2 text-center">
                <div class="text-yellow-600 font-bold text-lg">${stats.pending}</div>
                <div class="text-xs text-yellow-700">รอดำเนินการ</div>
            </div>
        </div>
        
        <div class="text-xs font-semibold text-gray-600 mb-1">แยกตามประเภท</div>
        <div class="space-y-1 mb-3">
    `;
    
    Object.entries(stats.byType).forEach(([type, count]) => {
        const pct = Math.round((count / stats.total) * 100);
        html += `
            <div class="flex items-center gap-2">
                <span class="badge ${typeCls(type)}">${type}</span>
                <div class="flex-1 bg-gray-200 rounded-full h-2">
                    <div class="bg-blue-400 h-2 rounded-full" style="width: ${pct}%"></div>
                </div>
                <span class="text-xs text-gray-600">${count}</span>
            </div>
        `;
    });
    
    html += `
        </div>
        <div class="text-xs font-semibold text-gray-600 mb-1">สถานะ</div>
        <div class="flex flex-wrap gap-1">
    `;
    
    Object.entries(stats.byStatus).forEach(([status, count]) => {
        html += `<span class="pill ${statusCls(status)}">${status}: ${count}</span>`;
    });
    
    html += '</div>';
    
    container.innerHTML = html;
}

function renderMonthlyChart() {
    const ctx = $('monthlyChart').getContext('2d');
    const stats = getMonthlyStats();
    
    const labels = [];
    const totalData = [];
    const doneData = [];
    const pendingData = [];
    
    for (let m = 0; m < 12; m++) {
        const key = `${selectedYear}-${String(m+1).padStart(2,'0')}`;
        const stat = stats[key] || { total: 0, done: 0, pending: 0 };
        
        labels.push(THAI_MONTHS[m]);
        totalData.push(stat.total);
        doneData.push(stat.done);
        pendingData.push(stat.pending);
    }
    
    if (monthlyChart) {
        monthlyChart.destroy();
    }
    
    monthlyChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [
                {
                    label: 'เสร็จสิ้น',
                    data: doneData,
                    backgroundColor: 'rgba(34, 197, 94, 0.7)',
                    borderColor: 'rgb(34, 197, 94)',
                    borderWidth: 1,
                    borderRadius: 3
                },
                {
                    label: 'รอดำเนินการ',
                    data: pendingData,
                    backgroundColor: 'rgba(251, 191, 36, 0.7)',
                    borderColor: 'rgb(251, 191, 36)',
                    borderWidth: 1,
                    borderRadius: 3
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { font: { size: 10 }, usePointStyle: true, boxWidth: 6 }
                }
            },
            scales: {
                x: { stacked: true, grid: { display: false } },
                y: { stacked: true, beginAtZero: true, grid: { color: '#f3f4f6' } }
            }
        }
    });
}

function render() {
    const cnt = { all: DOCS.length, 'หนังสือรับ': 0, 'คำสั่ง': 0, 'บันทึกข้อความ': 0, 'อื่นๆ': 0 };
    DOCS.forEach(d => cnt[d.type] !== undefined ? cnt[d.type]++ : cnt['อื่นๆ']++);
    $('cAll').textContent = cnt.all;
    $('cIn').textContent = cnt['หนังสือรับ'];
    $('cOrder').textContent = cnt['คำสั่ง'];
    $('cMemo').textContent = cnt['บันทึกข้อความ'];
    $('cOther').textContent = cnt['อื่นๆ'];
    
    let pend = 0, done = 0;
    DOCS.forEach(d => d.status.includes('เสร็จ') || d.status.includes('อนุมัติ') ? done++ : pend++);
    $('sTotal').textContent = DOCS.length;
    $('sPend').textContent = pend;
    $('sDone').textContent = done;
    
    applyFilters();
}

function applyFilters() {
    const mainTypes = ['หนังสือรับ', 'คำสั่ง', 'บันทึกข้อความ'];
    const monthVal = $('monthFilter').value;
    
    let list = DOCS;
    
    // Filter by type
    if (FILTER !== 'all') {
        list = list.filter(d => FILTER === 'อื่นๆ' ? !mainTypes.includes(d.type) : d.type === FILTER);
    }
    
    // Filter by month
    if (monthVal) {
        list = list.filter(d => {
            if (d.createdDate) {
                const parts = d.createdDate.split('/');
                if (parts.length >= 3) {
                    return (parts[1] + '/' + parts[2]) === monthVal;
                }
            }
            return false;
        });
    }
    
    renderTable(list);
}

function renderTable(list) {
    const tb = $('tBody');
    
    if (!list.length) { tb.innerHTML = ''; show('empty'); return; }
    hide('empty');
    
    const fragment = document.createDocumentFragment();
    list.forEach(d => {
        const tr = document.createElement('tr');
        const docNoDisplay = d.docNo || '-';
        tr.innerHTML = `
            <td class="px-4 py-3">
                <div class="font-bold text-blue-600">${esc(docNoDisplay)}</div>
                ${d.docNoOW ? `<div class="text-xs text-purple-500">${esc(d.docNoOW)}</div>` : ''}
            </td>
            <td class="px-4 py-3"><span class="badge ${typeCls(d.type)}">${esc(d.type)}</span><div class="text-xs text-gray-500 mt-1">${esc(d.date)}</div></td>
            <td class="px-4 py-3"><div class="max-w-[150px] sm:max-w-[250px] truncate" title="${esc(d.topic)}">${esc(d.topic)}</div></td>
            <td class="px-4 py-3 text-gray-500">${esc(d.owner)}</td>
            <td class="px-4 py-3"><span class="pill ${statusCls(d.status)}">${esc(d.status)}</span></td>
            <td class="px-4 py-3 text-center whitespace-nowrap">
                <button onclick="showQrWithData('${d.id}', '${esc(d.docNo)}', '${esc(d.createdDate)}', '${esc(d.createdTime)}', '${esc(d.type)}')" class="btn-icon text-indigo-600 hover:bg-indigo-100" title="QR Code"><i class="fas fa-qrcode"></i></button>
                <button onclick="goEdit('${d.id}')" class="btn-icon text-amber-600 hover:bg-amber-100" title="แก้ไข"><i class="fas fa-edit"></i></button>
                <button onclick="goUpdatePage('${d.id}')" class="btn-icon text-blue-600 hover:bg-blue-100" title="อัพเดทสถานะ"><i class="fas fa-tasks"></i></button>
                <button onclick="doDel('${d.id}')" class="btn-icon text-red-600 hover:bg-red-100" title="ลบ"><i class="fas fa-trash"></i></button>
            </td>`;
        fragment.appendChild(tr);
    });
    tb.innerHTML = '';
    tb.appendChild(fragment);
