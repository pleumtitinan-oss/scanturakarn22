<script>
// Config
// GitHub Pages + Google Apps Script backend configuration
// 1) Deploy Code.gs as Web App
// 2) Paste the /exec URL below
const GAS_WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbzw7Db657-lwjOB6ZWt0-KN9m42tR42IPIsy8imzf3LauSzGsfcYGWZluGjb4vcmdwjyQ/exec';

const URL_PARAMS = new URLSearchParams(window.location.search);
const MODE = (URL_PARAMS.get('view') === 'update') ? 'mobile_update' : (URL_PARAMS.get('view') === 'edit') ? 'edit_doc' : 'dashboard';
let DOC_ID = (URL_PARAMS.get('id') || '').trim();
let CFG = {}, DOCS = [], FILTER = 'all';
let CURRENT_QR_DATA = {};
let html5QrCode = null;
let monthlyChart = null;
let selectedMonth = null;
let selectedYear = new Date().getFullYear();

// Auto Refresh Config
let autoRefreshInterval = null;
const AUTO_REFRESH_SECONDS = 30;
let refreshCountdown = AUTO_REFRESH_SECONDS;

// Thai month names
const THAI_MONTHS = ['ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'];
const THAI_MONTHS_FULL = ['มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน', 'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'];

// JSONP bridge: GitHub Pages cannot use google.script.run, so every call goes to Apps Script Web App by JSONP.
function api(action, params = {}, timeoutMs = 30000) {
    return new Promise((resolve, reject) => {
        if (!GAS_WEB_APP_URL || GAS_WEB_APP_URL.includes('PASTE_YOUR_APPS_SCRIPT_WEB_APP_EXEC_URL_HERE')) {
            reject(new Error('ยังไม่ได้ตั้งค่า GAS_WEB_APP_URL ในไฟล์ index.html'));
            return;
        }

        const callbackName = '__gas_cb_' + Date.now() + '_' + Math.random().toString(36).slice(2);
        const qs = new URLSearchParams();
        qs.set('action', action);
        qs.set('callback', callbackName);

        Object.entries(params || {}).forEach(([key, value]) => {
            if (value === undefined || value === null) return;
            qs.set(key, typeof value === 'object' ? JSON.stringify(value) : String(value));
        });

        const script = document.createElement('script');
        const sep = GAS_WEB_APP_URL.includes('?') ? '&' : '?';
        const timer = setTimeout(() => {
            cleanup();
            reject(new Error('เชื่อมต่อ Apps Script ไม่สำเร็จ หรือใช้เวลานานเกินไป'));
        }, timeoutMs);

        function cleanup() {
            clearTimeout(timer);
            try { delete window[callbackName]; } catch (e) { window[callbackName] = undefined; }
            if (script.parentNode) script.parentNode.removeChild(script);
        }

        window[callbackName] = (payload) => {
            cleanup();
            resolve(payload);
        };

        script.onerror = () => {
            cleanup();
            reject(new Error('โหลด API จาก Apps Script ไม่สำเร็จ ตรวจสอบ Web App URL และการ Deploy'));
        };

        script.src = GAS_WEB_APP_URL + sep + qs.toString();
        document.body.appendChild(script);
    });
}

// Init
document.addEventListener('DOMContentLoaded', () => {
    api('getSettings').then(onCfg).catch(onErr);
});

function onCfg(r) {
    if (!r.success) return hide('loader') || Swal.fire('Error', r.error, 'error');
    CFG = r.data || {};
    // QR/update/edit links must point back to this GitHub Pages front-end, not the Apps Script /exec URL.
    CFG.API_URL = GAS_WEB_APP_URL;
    CFG.WEBAPP_URL = window.location.origin + window.location.pathname;
    
    if (CFG.SYSTEM_NAME) {
        document.title = CFG.SYSTEM_NAME;
        ['nameLogin', 'nameNav'].forEach(id => { if ($(id)) $(id).textContent = CFG.SYSTEM_NAME; });
    }
    if (CFG.LOGO_URL) ['logoLogin', 'logoNav'].forEach(id => { if ($(id)) $(id).src = CFG.LOGO_URL; });
    
    hide('loader');
    
    if (MODE === 'mobile_update' && DOC_ID) loadUpdate(DOC_ID);
    else if (MODE === 'edit_doc' && DOC_ID) loadEdit(DOC_ID);
    else checkAuthAndShow();
}

function checkAuthAndShow() {
    const urlParams = new URLSearchParams(window.location.search);
    const authFromUrl = urlParams.get('auth');
    
    if (authFromUrl === '1' || sessionStorage.getItem('auth') === '1') {
        sessionStorage.setItem('auth', '1');
        showDash();
    } else {
        show('vLogin');
        switchLoginTab('search'); // Default to search tab for public
    }
}

function onErr(e) { hide('loader'); Swal.fire('Error', e.message || e, 'error'); }

// Helpers
const $ = id => document.getElementById(id);
const show = id => { const el = $(id); if (el) el.classList.remove('hidden'); };
const hide = id => { const el = $(id); if (el) el.classList.add('hidden'); };
const esc = t => { const d = document.createElement('div'); d.textContent = t || ''; return d.innerHTML; };
function loader(on) { on ? show('loader') : hide('loader'); }

// Login Tab Logic
function switchLoginTab(mode) {
    const searchTab = $('tabSearch');
    const loginTab = $('tabLogin');
    const btnSearch = $('tabBtn-search');
    const btnLogin = $('tabBtn-login');

    if (mode === 'search') {
        searchTab.classList.remove('hidden');
        loginTab.classList.add('hidden');
        btnSearch.classList.add('active');
        btnLogin.classList.remove('active');
        $('publicSearchInput').focus();
    } else {
        searchTab.classList.add('hidden');
        loginTab.classList.remove('hidden');
        btnSearch.classList.remove('active');
        btnLogin.classList.add('active');
        $('pwd').focus();
    }
}

function doPublicSearch() {
    const kw = $('publicSearchInput').value.trim();
    if (!kw) return Swal.fire('แจ้งเตือน', 'กรุณากรอกคำค้นหา', 'warning');
    
    loader(true);
    api('searchPublicDocuments', { keyword: kw }).then(r => {
        loader(false);
        if(r.success) {
            renderPublicResults(r.data);
        } else {
            Swal.fire('Error', r.error, 'error');
        }
    }).catch(onErr);
}

function renderPublicResults(list) {
    const div = $('publicResults');
    div.innerHTML = '';
    
    if (!list.length) {
        div.innerHTML = '<div class="text-center text-gray-500 py-4">ไม่พบเอกสารที่ค้นหา</div>';
        return;
    }
    
    list.forEach(d => {
        const item = document.createElement('div');
        item.className = 'bg-gray-50 p-3 rounded border hover:bg-gray-100 cursor-pointer transition-colors';
        item.onclick = () => showPublicDetail(d);
        
        let docNoBadge = d.docNo ? `<span class="bg-blue-100 text-blue-800 text-xs px-2 py-0.5 rounded font-bold mr-1">${d.docNo}</span>` : '';
        let docNoOWBadge = d.docNoOW ? `<span class="bg-purple-100 text-purple-800 text-xs px-2 py-0.5 rounded font-bold mr-1">${d.docNoOW}</span>` : '';
        
        item.innerHTML = `
            <div class="flex justify-between items-start mb-1">
                <div>
                   ${docNoBadge}${docNoOWBadge}
                   <span class="text-xs text-gray-400">${d.date}</span>
                </div>
                <span class="pill ${statusCls(d.status)} scale-90 origin-top-right">${d.status}</span>
            </div>
            <div class="font-medium text-gray-800 truncate">${d.topic}</div>
        `;
        div.appendChild(item);
    });
}

function showPublicDetail(d) {
    $('pdDocNo').textContent = d.docNo || '-';
    $('pdDocNoOW').textContent = d.docNoOW || '-';
    $('pdTopic').textContent = d.topic || '-';
    $('pdDate').textContent = d.date || '-';
    $('pdStatus').textContent = d.status || '-';
    $('pdStatus').className = 'pill ' + statusCls(d.status);
